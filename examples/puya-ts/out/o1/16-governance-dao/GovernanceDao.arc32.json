    "contract": {
        "name": "GovernanceDao",
        "methods": [
            {
                "name": "createApplication",
                "args": [],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Deploy the contract; GlobalState values are auto-initialized."
            },
            {
                "name": "bootstrap",
                "args": [
                    {
                        "type": "uint64",
                        "name": "quorum",
                        "desc": "- minimum yes-votes required to execute a proposal"
                    },
                    {
                        "type": "uint64",
                        "name": "votingPeriod",
                        "desc": "- number of rounds a proposal stays open for voting"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Configure DAO parameters (quorum and voting period); creator-only, one-time setup."
            },
            {
                "name": "propose",
                "args": [
                    {
                        "type": "string",
                        "name": "description",
                        "desc": "- human-readable proposal description"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "uint64",
                    "desc": "the newly assigned proposal ID"
                },
                "desc": "Submit a new proposal and emit a ProposalCreated event; returns the proposal ID."
            },
            {
                "name": "vote",
                "args": [
                    {
                        "type": "uint64",
                        "name": "proposalId",
                        "desc": "- the ID of the proposal to vote on"
                    },
                    {
                        "type": "bool",
                        "name": "inFavor",
                        "desc": "- true for yes, false for no"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Cast a yes/no vote on an open proposal with deduplication."
            },
            {
                "name": "execute",
                "args": [
                    {
                        "type": "uint64",
                        "name": "proposalId",
                        "desc": "- the ID of the proposal to execute"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Execute a proposal that reached quorum after voting ends."
            },
            {
                "name": "tally",
                "args": [],
                "readonly": false,
                "returns": {
                    "type": "uint64",
                    "desc": "the number of proposals that reached the quorum threshold"
                },
                "desc": "Count and return the number of proposals that met quorum."
            },
            {
                "name": "close",
                "args": [],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Shut down the DAO, delete all proposal boxes, and emit a DaoClosed event; creator-only."
            }
        ],
        "networks": {}
    },
    "bare_call_config": {}
