                "name": "destructuredParam",
                "args": [
                    {
                        "type": "(uint64,uint64)",
                        "name": "p"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "uint64",
                    "desc": "the product of x and y"
                },
                "desc": "Destructured object parameter \u2014 fields extracted inline in the signature."
