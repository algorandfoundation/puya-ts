                "returns": {
                    "type": "uint64",
                    "desc": "the squared distance between start and end"
                },
                "desc": "Nested object as param \u2014 Segment contains two Vectors."
            },
            {
                "name": "saveVector",
                "args": [
                    {
                        "type": "(uint64,uint64)",
                        "name": "v",
                        "desc": "- vector to persist on-chain"
                    }
                ],
