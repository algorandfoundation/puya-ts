                    "type": "void"
                },
                "desc": "Store a nested object in GlobalState."
            },
            {
                "name": "getSavedVector",
                "args": [],
                "readonly": true,
                "returns": {
                    "type": "(uint64,uint64)",
                    "desc": "the saved vector from GlobalState"
