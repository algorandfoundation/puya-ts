                ],
                "readonly": false,
                "returns": {
                    "type": "(uint64,uint64)",
                    "desc": "a new vector with the same field values"
                },
                "desc": "Spread operator to create a new object from an existing one."
            },
            {
                "name": "magnitudeSquared",
                "args": [
                    {
                        "type": "(uint64,uint64)",
                        "name": "v",
                        "desc": "- vector to compute magnitude squared for"
