            },
            {
                "name": "getSavedSegment",
                "args": [],
                "readonly": true,
                "returns": {
                    "type": "((uint64,uint64),(uint64,uint64))",
                    "desc": "the saved segment from GlobalState"
                },
                "desc": "Return nested object from state."
            },
            {
                "name": "testCopyAndMutate",
                "args": [
                    {
                        "type": "(uint64,uint64)",
                        "name": "v",
                        "desc": "- original vector to copy"
                    },
                    {
                        "type": "uint64",
                        "name": "newX",
                        "desc": "- new x value for the copy"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "(uint64,uint64)",
                    "desc": "a mutated copy of the original vector"
                },
                "desc": "Spread operator and clone for object copying."
            },
            {
                "name": "testSpread",
                "args": [
                    {
                        "type": "(uint64,uint64)",
                        "name": "v",
                        "desc": "- vector to spread-copy"
