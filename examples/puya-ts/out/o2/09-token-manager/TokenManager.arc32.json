    "contract": {
        "name": "TokenManager",
        "methods": [
            {
                "name": "createApplication",
                "args": [],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Initialize the application \u2014 asset is created separately via createToken."
            },
            {
                "name": "createToken",
                "args": [
                    {
                        "type": "string",
                        "name": "name",
                        "desc": "- Full name of the asset"
                    },
                    {
                        "type": "string",
                        "name": "unitName",
                        "desc": "- Short unit name (e.g. \"TKN\")"
                    },
                    {
                        "type": "uint64",
                        "name": "total",
                        "desc": "- Total supply of the token"
                    },
                    {
                        "type": "uint64",
                        "name": "decimals",
                        "desc": "- Decimal places for display"
                    },
                    {
                        "type": "string",
                        "name": "url",
                        "desc": "- URL with asset metadata"
                    },
                    {
                        "type": "bool",
                        "name": "defaultFrozen",
                        "desc": "- Whether new holders start frozen"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "uint64",
                    "desc": "The created asset ID"
                },
                "desc": "Create a new ASA via inner transaction.\nThe contract becomes manager, reserve, freeze, and clawback authority."
            },
            {
                "name": "optInToAsset",
                "args": [
                    {
                        "type": "uint64",
                        "name": "asset",
                        "desc": "- The managed asset to opt into"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Opt the contract into the managed asset so it can hold tokens.\nA zero-amount self-transfer is the standard opt-in pattern."
            },
            {
                "name": "transfer",
                "args": [
                    {
                        "type": "uint64",
                        "name": "asset",
                        "desc": "- The managed asset to transfer"
                    },
                    {
                        "type": "address",
                        "name": "receiver",
                        "desc": "- Destination account"
                    },
                    {
                        "type": "uint64",
                        "name": "amount",
                        "desc": "- Number of tokens to send"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Transfer tokens from the contract to a receiver."
            },
            {
                "name": "clawback",
                "args": [
                    {
                        "type": "uint64",
                        "name": "asset",
                        "desc": "- The managed asset"
                    },
                    {
                        "type": "address",
                        "name": "target",
                        "desc": "- Account to clawback from"
                    },
                    {
                        "type": "uint64",
                        "name": "amount",
                        "desc": "- Amount to clawback"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Clawback tokens from a holder back to the contract.\nUses the assetSender field to revoke from the target account."
            },
            {
                "name": "freezeAccount",
                "args": [
                    {
                        "type": "uint64",
                        "name": "asset",
                        "desc": "- The managed asset"
                    },
                    {
                        "type": "address",
                        "name": "target",
                        "desc": "- Account to freeze/unfreeze"
                    },
                    {
                        "type": "bool",
                        "name": "frozen",
                        "desc": "- true to freeze, false to unfreeze"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Freeze or unfreeze an account's holdings of the managed asset."
            },
            {
                "name": "verifyAssetConfig",
                "args": [
                    {
                        "type": "uint64",
                        "name": "asset",
                        "desc": "- The managed asset to verify"
                    }
                ],
                "readonly": true,
                "returns": {
                    "type": "uint64",
                    "desc": "The total supply of the asset"
                },
                "desc": "Read on-chain asset properties to verify configuration.\nDemonstrates Asset reference property access."
            },
            {
                "name": "destroyToken",
                "args": [
                    {
                        "type": "uint64",
                        "name": "asset",
                        "desc": "- The managed asset to destroy"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Destroy the managed asset.\nThe creator must hold all units and be the sender."
            }
        ],
        "networks": {}
    },
    "bare_call_config": {}
}