    "contract": {
        "name": "MultiTxnDistributor",
        "methods": [
            {
                "name": "createApplication",
                "args": [],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Initialize the application."
            },
            {
                "name": "distributePair",
                "args": [
                    {
                        "type": "pay",
                        "name": "funding",
                        "desc": "- the outer group payment transaction funding the distribution"
                    },
                    {
                        "type": "address",
                        "name": "recipientA",
                        "desc": "- first recipient account"
                    },
                    {
                        "type": "address",
                        "name": "recipientB",
                        "desc": "- second recipient account"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Distribute equal payment to exactly two recipients using itxn.submitGroup.\nDemonstrates typed tuple return \u2014 each element is strongly typed."
            },
            {
                "name": "distributeWithOptIn",
                "args": [
                    {
                        "type": "pay",
                        "name": "funding",
                        "desc": "- the outer group payment transaction funding the distribution"
                    },
                    {
                        "type": "uint64",
                        "name": "asset",
                        "desc": "- the asset to opt into"
                    },
                    {
                        "type": "address",
                        "name": "recipientA",
                        "desc": "- first recipient account"
                    },
                    {
                        "type": "address",
                        "name": "recipientB",
                        "desc": "- second recipient account"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Distribute funding plus opt-in to an asset for two recipients.\nDemonstrates mixed-type submitGroup (payment + asset transfer)."
            },
            {
                "name": "distributeDynamic",
                "args": [
                    {
                        "type": "pay",
                        "name": "funding",
                        "desc": "- the outer group payment transaction funding the distribution"
                    },
                    {
                        "type": "address[]",
                        "name": "recipients",
                        "desc": "- array of recipient addresses"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Distribute funds to a dynamic list of recipients using itxnCompose.\nDemonstrates .begin() / .next() / .submit() for variable-size groups."
            },
            {
                "name": "verifyGroupPayments",
                "args": [],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Verify that all preceding transactions in the outer group are payments.\nDemonstrates gtxn.Transaction() access and TransactionType enum checks."
            }
        ],
