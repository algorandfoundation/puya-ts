    "schema": {
        "global": {
            "declared": {
                "secretHash": {
                    "type": "bytes",
                    "key": "secretHash"
                }
            },
            "reserved": {}
        },
        "local": {
            "declared": {},
            "reserved": {}
        }
    },
    "contract": {
        "name": "CryptoVault",
        "methods": [
            {
                "name": "createApplication",
                "args": [
                    {
                        "type": "byte[]",
                        "name": "commitment",
                        "desc": "- the secret value to hash and store as the vault commitment"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Create the vault by storing a SHA-256 hash of the secret."
            },
            {
                "name": "hashShowcase",
                "args": [
                    {
                        "type": "byte[]",
                        "name": "data",
                        "desc": "- the input data to hash with all four algorithms"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "byte[]",
                    "desc": "concatenation of all four hash outputs (128 bytes total)"
                },
                "desc": "Demonstrate all four hash algorithms on the same input."
            },
            {
                "name": "verifyAndUnlock",
                "args": [
                    {
                        "type": "byte[]",
                        "name": "data",
                        "desc": "- the original message that was signed"
                    },
                    {
                        "type": "byte[]",
                        "name": "signature",
                        "desc": "- the 64-byte Ed25519 signature"
                    },
                    {
                        "type": "byte[]",
                        "name": "publicKey",
                        "desc": "- the 32-byte Ed25519 public key"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "bool",
                    "desc": "true if the signature is valid"
                },
                "desc": "Verify an Ed25519 signature and unlock the vault."
            },
            {
                "name": "scratchCounter",
                "args": [
                    {
                        "type": "uint64",
                        "name": "iterations",
                        "desc": "- the uint64 value to store, load, and double via scratch space"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "uint64",
                    "desc": "the doubled value read back from scratch space"
                },
                "desc": "Demonstrate scratch space with uint64 values."
            },
            {
                "name": "checkPreimage",
                "args": [
                    {
                        "type": "byte[]",
                        "name": "preimage",
                        "desc": "- the candidate preimage to check against the stored hash"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "bool",
                    "desc": "true if the preimage hashes to the stored commitment"
                },
                "desc": "Verify a preimage matches the stored commitment."
            }
        ],
        "networks": {}
    },
    "bare_call_config": {}
}