#pragma version 11
#pragma typetrack false

// examples/puya-ts/13-inheritance-showcase/contract.algo.ts::AuditedProcessor.approvalProgram() -> uint64:
main:
    intcblock 0 1
    bytecblock "auditCount"
    b main_block@0

main_block@0:
    txn ApplicationID
    bnz main_after_if_else@2
    b main_if_body@1

main_if_body@1:
    callsub constructor
    b main_after_if_else@2

main_after_if_else@2:
    // examples/puya-ts/13-inheritance-showcase/contract.algo.ts:60
    // this.recordAudit() // Call inherited protected method from Auditable
    callsub recordAudit
    // examples/puya-ts/13-inheritance-showcase/contract.algo.ts:61
    // log(this.auditCount.value) // Access inherited state
    intc_0 // 0
    // examples/puya-ts/13-inheritance-showcase/contract.algo.ts:34
    // auditCount = GlobalState({ initialValue: Uint64(0) })
    bytec_0 // "auditCount"
    // examples/puya-ts/13-inheritance-showcase/contract.algo.ts:61
    // log(this.auditCount.value) // Access inherited state
    app_global_get_ex
    assert // check GlobalState exists
    itob
    log
    // examples/puya-ts/13-inheritance-showcase/contract.algo.ts:62
    // return true
    intc_1 // 1
    return


// examples/puya-ts/13-inheritance-showcase/contract.algo.ts::Auditable.recordAudit() -> void:
recordAudit:
    b recordAudit_block@0

recordAudit_block@0:
    // examples/puya-ts/13-inheritance-showcase/contract.algo.ts:39
    // const next: uint64 = this.auditCount.value + 1
    intc_0 // 0
    // examples/puya-ts/13-inheritance-showcase/contract.algo.ts:34
    // auditCount = GlobalState({ initialValue: Uint64(0) })
    bytec_0 // "auditCount"
    // examples/puya-ts/13-inheritance-showcase/contract.algo.ts:39
    // const next: uint64 = this.auditCount.value + 1
    app_global_get_ex
    assert // check GlobalState exists
    intc_1 // 1
    +
    // examples/puya-ts/13-inheritance-showcase/contract.algo.ts:34
    // auditCount = GlobalState({ initialValue: Uint64(0) })
    bytec_0 // "auditCount"
    // examples/puya-ts/13-inheritance-showcase/contract.algo.ts:40
    // this.auditCount.value = next
    uncover 1
    app_global_put
    retsub


// examples/puya-ts/13-inheritance-showcase/contract.algo.ts::AuditedProcessor.constructor() -> void:
constructor:
    b constructor_block@0

constructor_block@0:
    // examples/puya-ts/13-inheritance-showcase/contract.algo.ts:51
    // super() // Required super() call in derived constructor
    callsub examples/puya-ts/13-inheritance-showcase/contract.algo.ts::Auditable.constructor
    // examples/puya-ts/13-inheritance-showcase/contract.algo.ts:47
    // callTag = GlobalState<uint64>()
    pushbytes "callTag"
    // examples/puya-ts/13-inheritance-showcase/contract.algo.ts:52
    // this.callTag.value = 42 // Initialise level-specific state
    pushint 42
    app_global_put
    retsub


