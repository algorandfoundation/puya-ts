    "contract": {
        "name": "TypeExplorer",
        "methods": [
            {
                "name": "exploreUint64",
                "args": [
                    {
                        "type": "uint64",
                        "name": "a",
                        "desc": "- first uint64 operand"
                    },
                    {
                        "type": "uint64",
                        "name": "b",
                        "desc": "- second uint64 operand"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "uint64",
                    "desc": "the sum after a uint64 \u2192 bytes \u2192 uint64 round trip"
                },
                "desc": "Demonstrate uint64 factories and arithmetic, returning the round-tripped value."
            },
            {
                "name": "exploreBigUint",
                "args": [
                    {
                        "type": "uint64",
                        "name": "value",
                        "desc": "- uint64 to convert and square"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "uint512",
                    "desc": "the integer square root of value\u00b2"
                },
                "desc": "Demonstrate biguint factories, conversion from uint64, and op.bsqrt."
            },
            {
                "name": "exploreBytes",
                "args": [
                    {
                        "type": "byte[]",
                        "name": "input",
                        "desc": "- arbitrary bytes to hash"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "byte[]",
                    "desc": "SHA-256 hash of the concatenated input"
                },
                "desc": "Demonstrate Bytes() factory, Bytes.fromHex(), op.sha256, and bytes-to-biguint conversion."
            },
            {
                "name": "exploreWideMath",
                "args": [
                    {
                        "type": "uint64",
                        "name": "a",
                        "desc": "- first uint64 operand"
                    },
                    {
                        "type": "uint64",
                        "name": "b",
                        "desc": "- second uint64 operand"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "uint64",
                    "desc": "the low 64 bits of the 128-bit sum"
                },
                "desc": "Demonstrate op.addw (128-bit addition) and op.itob / op.btoi conversions."
            }
        ],
        "networks": {}
    },
    "bare_call_config": {
        "no_op": "CREATE"
    }
}