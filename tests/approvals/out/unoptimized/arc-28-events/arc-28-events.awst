contract EventEmitter
{
  approvalProgram(): bool
  {
    return arc4Router()
  }
  
  clearProgram(): bool
  {
    return True
  }
  
  emitSwapped(a: arc4.uint8, b: arc4.uint8): void
  {
    emit("tests/approvals/arc-28-events.algo.ts::Swapped", new tests/approvals/arc-28-events.algo.ts::Swapped(a=b, b=a))
    x: tests/approvals/arc-28-events.algo.ts::Swapped = new tests/approvals/arc-28-events.algo.ts::Swapped(a=($0 = #{ a: b, b: a }).a, b=$0.b)
    emit("tests/approvals/arc-28-events.algo.ts::Swapped", x)
    y: SwappedArc4 = new SwappedArc4(a=($1 = #{ a: b, b: a }).a, b=$1.b)
    emit("SwappedArc4", y)
    emit_fields(Swapped, (b, a))
    emit_fields(Swapped(uint8,uint8), (b, a))
    emit_fields(Swapped((uint8,uint8),uint8), (#[b, b], a))
    emit_fields(Swapped((uint8,uint8),uint8), (ARC4_ENCODE(#[b, b], wtype=arc4.tuple<arc4.uint8,arc4.uint8>), a))
    emit_fields(Swapped(uint8[],uint8), (ARC4_ENCODE(#[b, b], wtype=arc4.dynamic_array<arc4.uint8>), a))
    emit_fields(Swapped(((uint8,uint8)),uint8), (ARC4_ENCODE(#[#[b, b]], wtype=arc4.tuple<arc4.tuple<arc4.uint8,arc4.uint8>>), a))
    emit_fields(Swapped(uint8[][],uint8), (ARC4_ENCODE(#[#[b, b]], wtype=arc4.dynamic_array<arc4.dynamic_array<arc4.uint8>>), a))
    emit_fields(Swapped((uint8,uint8)[],uint8), (ARC4_ENCODE(#[#[b, b]], wtype=arc4.dynamic_array<arc4.tuple<arc4.uint8,arc4.uint8>>), a))
    emit_fields(Swapped((uint8[]),uint8), (ARC4_ENCODE(#[#[b, b]], wtype=arc4.tuple<arc4.dynamic_array<arc4.uint8>>), a))
    aUint64: uint64 = ARC4_DECODE(a)
    bUint64: uint64 = ARC4_DECODE(b)
    emit_fields(Swapped(uint64[],uint64), (ARC4_ENCODE(#[bUint64, bUint64], wtype=arc4.dynamic_array<arc4.uint64>), aUint64))
  }
  
  emitCustom(arg0: string, arg1: bool): void
  {
    emit_fields(Custom, (arg0, arg1))
    emit_fields(Custom(string,bool), (arg0, arg1))
  }
  
  emitDynamicBytes(x: bytes, y: arc4.dynamic_array<arc4.byte>): void
  {
    emit_fields(DB(byte[],byte[]), (x, y))
  }
  
  __algots__.defaultCreate(): void
  {
  }
  
}